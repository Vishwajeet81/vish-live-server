{
  "name": "vish-live-server",
  "displayName": "Vish Live Server",
  "description": "A lightweight VS Code Live Server built from scratch using Node.js with WebSocket-based live reload, automatic browser launch, Explorer context menu support, and status bar integration.",
  "version": "0.2.4",
  "publisher": "Vishwajeet81",
  "license": "MIT",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "live-server",
    "live reload",
    "websocket",
    "html",
    "css",
    "javascript",
    "nodejs",
    "vscode",
    "web",
    "development"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vish-live-server.goLive",
        "title": "Go Live"
      },
      {
        "command": "vish-live-server.stop",
        "title": "Stop Live Server"
      },
      {
        "command": "vish-live-server.preview",
        "title": "Vish Preview Server"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "vish-live-server.goLive",
          "when": "resourceExtname == '.html'"
        },
        {
          "command": "vish-live-server.preview",
          "when": "resourceExtname == '.html'"
        }
      ],
      "editor/context": [
        {
          "command": "vish-live-server.goLive",
          "when": "resourceExtname == '.html'"
        },
        {
          "command": "vish-live-server.preview",
          "when": "resourceExtname == '.html'"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vishwajeet81/vish-live-server.git"
  },
  "bugs": {
    "url": "https://github.com/Vishwajeet81/vish-live-server/issues"
  },
  "homepage": "https://github.com/Vishwajeet81/vish-live-server#readme",
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "dependencies": {
    "open": "^11.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.5.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}